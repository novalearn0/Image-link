# ── Telegram API credentials ─────────────────────────────────────────────────
# Get these from https://my.telegram.org/apps
API_ID=12345678
API_HASH=abcdef1234567890abcdef1234567890

# ── Bot token ─────────────────────────────────────────────────────────────────
# Get this from @BotFather on Telegram
BOT_TOKEN=123456789:AABBccDDeeFFggHHiiJJkkLLmmNN

# ── Your Telegram user ID ─────────────────────────────────────────────────────
# Only this user can run bot commands.
# Find your ID via @userinfobot
OWNER_ID=987654321

# ── Channels ──────────────────────────────────────────────────────────────────
# Accepts:
#   Private channel:  -1001234567890   (full negative ID)
#   Private channel:  1234567890       (will be auto-prefixed with -100)
#   Public channel:   @channelusername
#   Public channel:   channelusername
SOURCE_CHANNEL=-1001234567890
DESTINATION_CHANNEL=-1009876543210
